#!/bin/bash
set -e

# SageMaker extracts model.tar.gz to /opt/ml/model/
MODEL_REPO=/opt/ml/model/python_backend_model_repository

echo "Starting Triton Server with model repository at $MODEL_REPO"
ls -R /opt/ml/model

# Check if model repository exists
if [ ! -d "$MODEL_REPO" ]; then
    echo "Error: Model repository not found at $MODEL_REPO"
    if [ -f "/opt/ml/model/config.pbtxt" ]; then
        MODEL_REPO=/opt/ml/model
        echo "Found config.pbtxt in /opt/ml/model, using that as repo."
    else
        echo "Could not find model repository."
        exit 1
    fi
fi

# Start Triton in background
echo "Starting Triton on port 8000..."
tritonserver \
  --model-repository=$MODEL_REPO \
  --http-port=8000 \
  --grpc-port=8001 \
  --metrics-port=8002 \
  --backend-config=python,python-runtime=/opt/miniconda/bin/python \
  --log-verbose=1 &

TRITON_PID=$!

# Wait for Triton to be ready
echo "Waiting for Triton to be ready..."
for i in {1..120}; do
    if curl -s http://localhost:8000/v2/health/ready > /dev/null 2>&1; then
        echo "Triton is ready!"
        break
    fi
    if ! kill -0 $TRITON_PID 2>/dev/null; then
        echo "Triton process died"
        exit 1
    fi
    sleep 1
done

# Start nginx (proxies /ping and /invocations for SageMaker)
echo "Starting nginx proxy on port 8080..."
nginx -c /opt/nginx.conf

# Keep container running by waiting on Triton
wait $TRITON_PID
