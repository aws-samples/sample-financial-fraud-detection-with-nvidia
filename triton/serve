#!/bin/bash
set -e

# SageMaker extracts model.tar.gz to /opt/ml/model/
SAGEMAKER_MODEL_REPO=/opt/ml/model/

echo "Starting Triton Server with SageMaker integration"
echo "Model repository: ${SAGEMAKER_MODEL_REPO}"
ls -lR ${SAGEMAKER_MODEL_REPO}

# Validate model repository structure
if [ -f "${SAGEMAKER_MODEL_REPO}/config.pbtxt" ]; then
    echo "ERROR: Incorrect directory structure."
    echo "       Model directory needs to contain the top level folder"
    echo "       Expected: /opt/ml/model/<model_name>/config.pbtxt"
    echo "       Found: /opt/ml/model/config.pbtxt"
    exit 1
fi

# Build Triton arguments for SageMaker
SAGEMAKER_ARGS="--model-repository=${SAGEMAKER_MODEL_REPO}"
SAGEMAKER_ARGS="${SAGEMAKER_ARGS} --model-namespacing=true"
SAGEMAKER_ARGS="${SAGEMAKER_ARGS} --allow-grpc=false"
SAGEMAKER_ARGS="${SAGEMAKER_ARGS} --allow-metrics=false"
SAGEMAKER_ARGS="${SAGEMAKER_ARGS} --log-verbose=true"

# Auto-detect model name if not specified
if [ -z "$SAGEMAKER_TRITON_DEFAULT_MODEL_NAME" ]; then
    MODEL_DIRS=($(find "${SAGEMAKER_MODEL_REPO}" -mindepth 1 -maxdepth 1 -type d -printf "%f\n"))
    case ${#MODEL_DIRS[@]} in
        0) echo "ERROR: No model found in model repository"
           exit 1
           ;;
        1) echo "Auto-detected model: ${MODEL_DIRS[0]}"
           export SAGEMAKER_TRITON_DEFAULT_MODEL_NAME=${MODEL_DIRS[0]}
           ;;
        *) echo "ERROR: Multiple model directories found: ${MODEL_DIRS[@]}"
           echo "       Set SAGEMAKER_TRITON_DEFAULT_MODEL_NAME to specify which model to load"
           exit 1
           ;;
    esac
fi

SAGEMAKER_ARGS="${SAGEMAKER_ARGS} --load-model=${SAGEMAKER_TRITON_DEFAULT_MODEL_NAME}"

echo "Loading model: ${SAGEMAKER_TRITON_DEFAULT_MODEL_NAME}"
echo "Starting Triton with SageMaker integration..."

# Start Triton with SageMaker integration
exec tritonserver \
  --allow-sagemaker=true \
  --allow-http=false \
  --model-control-mode=explicit \
  ${SAGEMAKER_ARGS}
